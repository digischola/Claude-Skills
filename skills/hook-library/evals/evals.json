{
  "skill": "hook-library",
  "version": "1.0.0",
  "test_cases": [
    {
      "id": "sync_from_post_writer_seeds_catalog",
      "description": "sync-from-post-writer parses 35+ patterns from the markdown reference",
      "command": "hook_lib.py sync-from-post-writer",
      "expected_exit": 0,
      "expected_stdout_contains": ["sync-from-post-writer complete", "Total in catalog:"]
    },
    {
      "id": "list_filters_by_tier",
      "description": "list --tier 2 returns only Tier 2 patterns (default after sync)",
      "command": "hook_lib.py list --tier 2 --json",
      "expected_exit": 0,
      "expected_json_field_min_length": {"$": 30}
    },
    {
      "id": "list_filters_by_pillar",
      "description": "list --pillar lp-craft returns only patterns tagged with lp-craft",
      "command": "hook_lib.py list --pillar lp-craft --json",
      "expected_exit": 0,
      "expected_json_field_each_contains": {"$.best_for.pillars": "lp-craft"}
    },
    {
      "id": "get_returns_full_pattern",
      "description": "get <id> returns the full pattern JSON with all fields",
      "command": "hook_lib.py get numbers-hero",
      "expected_exit": 0,
      "expected_stdout_contains": ["\"id\"", "\"tier\"", "\"best_for\"", "\"formula\""]
    },
    {
      "id": "get_unknown_id_fails",
      "description": "get <unknown-id> exits 1",
      "command": "hook_lib.py get not-a-real-pattern",
      "expected_exit": 1,
      "expected_stdout_contains": ["Pattern not found"]
    },
    {
      "id": "search_finds_by_keyword",
      "description": "search 'contrarian' returns matching patterns",
      "command": "hook_lib.py search contrarian --limit 5",
      "expected_exit": 0,
      "expected_stdout_contains": ["matches"]
    },
    {
      "id": "promote_changes_tier_and_logs",
      "description": "promote <id> bumps tier + writes to promotion-log.json",
      "command": "hook_lib.py promote numbers-hero --reason 'test promotion'",
      "expected_exit": 0,
      "expected_stdout_contains": ["changed", "T2 → T1"]
    },
    {
      "id": "demote_changes_tier_back",
      "description": "demote <id> moves T1 → T2",
      "command": "hook_lib.py demote numbers-hero --reason 'test demotion'",
      "expected_exit": 0,
      "expected_stdout_contains": ["changed", "T1 → T2"]
    },
    {
      "id": "tier_1_cap_enforced",
      "description": "promote refuses 9th Tier 1 pattern in same pillar",
      "command": "hook_lib.py promote pattern-X --reason 'should fail'",
      "fixture": "fixtures/lp_craft_with_8_tier1/",
      "expected_exit": 1,
      "expected_stdout_contains": ["REFUSED", "cap"]
    },
    {
      "id": "mark_used_increments_count",
      "description": "mark-used --id <id> increments use_count",
      "command": "hook_lib.py mark-used --id numbers-hero",
      "expected_exit": 0,
      "expected_stdout_contains": ["marked used", "count=1"]
    },
    {
      "id": "add_creates_tier_3_pattern",
      "description": "add --json '<payload>' creates a new pattern at Tier 3 by default",
      "command": "hook_lib.py add --json '{\"id\":\"founder-vulnerability-confession\",\"name\":\"Founder Vulnerability Confession\",\"category\":\"personal-stake\",\"formula\":\"I lost X because Y. Here is the lesson.\",\"examples\":[\"...\"],\"best_for\":{\"pillars\":[\"solo-ops\"],\"channels\":[\"linkedin\"],\"formats\":[\"text-post\"]}}'",
      "expected_exit": 0,
      "expected_stdout_contains": ["added", "T3"]
    },
    {
      "id": "add_duplicate_id_fails",
      "description": "add with existing id exits 1",
      "command": "hook_lib.py add --json '{\"id\":\"numbers-hero\",\"name\":\"dup\",\"category\":\"data\",\"formula\":\"...\",\"examples\":[],\"best_for\":{\"pillars\":[],\"channels\":[],\"formats\":[]}}'",
      "expected_exit": 1,
      "expected_stdout_contains": ["already exists"]
    },
    {
      "id": "stats_shows_tier_breakdown",
      "description": "stats prints per-tier and per-pillar counts",
      "command": "hook_lib.py stats",
      "expected_exit": 0,
      "expected_stdout_contains": ["Total patterns:", "By tier:", "By pillar × tier:", "By category:"]
    },
    {
      "id": "promotion_log_shows_history",
      "description": "promotion-log shows recent tier changes",
      "command": "hook_lib.py promotion-log --limit 5",
      "expected_exit": 0,
      "expected_stdout_contains": ["tier changes"]
    },
    {
      "id": "suggest_tier_moves_returns_empty_with_no_data",
      "description": "suggest-tier-moves returns empty arrays when no performance signals exist",
      "command": "hook_lib.py suggest-tier-moves --json",
      "expected_exit": 0,
      "expected_json_field": {"to_promote_to_tier_1": [], "to_demote_from_tier_1": []}
    },
    {
      "id": "export_writes_post_writer_mirror",
      "description": "export --target post-writer regenerates the markdown reference",
      "command": "hook_lib.py export --target post-writer --out /tmp/test-export.md",
      "expected_exit": 0,
      "expected_stdout_contains": ["exported"],
      "expected_file_at": "/tmp/test-export.md"
    }
  ],
  "fixtures_dir": "fixtures/",
  "notes": "Tests run against a fresh data/hooks.json. Some tests use fixtures (e.g., lp_craft_with_8_tier1/) to pre-seed cap conditions. Tests should be run in sequence as some depend on prior state (e.g., promote → demote)."
}
