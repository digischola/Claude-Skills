      "expected": {
        "entry_type": "trend",
        "source_url_present": true,
        "relevance_score": 8
      }
    },
    {
      "id": "trend-scan-skip-low-score",
      "mode": "trend-scan",
      "input": {
        "pillar": "Solo Freelance Ops",
