        "url": "https://example.com/irrelevant",
        "score": 3
      },
      "expected": {
        "appended": false,
        "reason": "score < 6"
      }
    },
    {
      "id": "trend-scan-skip-dup-url",
      "mode": "trend-scan",
      "input": {
        "pillar": "Landing-Page Conversion Craft",
        "headline": "(same headline, second run)",
        "url": "https://example.com/wellness-lp-benchmarks-2026",
        "score": 8
      },
      "expected": {
        "appended": false,
        "reason": "duplicate source_url"
      }
    },
    {
      "id": "peer-scan-pattern-borrow",
      "mode": "peer-scan",
